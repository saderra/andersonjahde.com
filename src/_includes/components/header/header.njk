{% include "components/header/off-canvas.njk" %}

<!-- Top bar -->
<div class="bg-ajgrey text-white">
  <div class="container mx-auto">
    <div class="flex flex-wrap items-center py-3">
      <div class="w-2/3 sm:w-1/2 overflow-hidden">
        <a href="https://drfreer.clientsecure.me/" class="inline-flex text-toptext text-center leading-none font-medium poppins uppercase" target="_blank">Denver Tax Attorneys</a>
      </div>
      <div class="w-1/3 sm:w-1/2 overflow-hidden text-right">
        <span class="inline-flex text-toptext leading-none font-medium poppins uppercase">Call Now: <a href="tel:{{ site.phone }}">{{ site.phone }}</a></span>
      </div>
    </div>
  </div>
</div>

<!-- Main header -->
<header class="sticky top-0 z-50 py-4 bg-white">
  <nav x-data="{ open: false }" role="navigation" aria-label="Main Menu">
    <div class="container mx-auto">
      <div class="flex items-center justify-between h-24">
        <div class="shrink-0">
          {% include "components/global/logo.njk" %}
        </div>

        {% include "components/header/desktop-links.njk" %}

        <!-- Mobile button -->
        <div class="-mr-1 flex lg:hidden">
          <button
            type="button"
            @click="open = !open"
            class="inline-flex p-2 items-center justify-start rounded-md text-stone-600 hover:text-stone-600 hover:bg-stone-100 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-indigo-500"
            aria-controls="mobile-menu"
            aria-expanded="false"
          >
            <span class="sr-only">Open Main Menu</span>
            <svg
              x-description="Close Icons"
              x-state:on="Menu open"
              x-state:off="Menu closed"
              class="h-7 w-7 block"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              @click="$dispatch('offcanvas')"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </nav>
</header>

<!-- Sub-header -->
<div class="bg-ajblue poppins font-medium">
  <div class="container mx-auto text-white py-3">
    <div class="block md:grid grid-cols-2 grid-rows-1 gap-4">
      <div class="text-left hidden md:block"><span>Denver Based Tax Attorneys Since 1995</span></div>
      <div class="text-center md:text-right">Call Now: <a href="tel:{{ site.phone }}">{{ site.phone }}</a></div>
    </div>
  </div>
</div>
